{
  "rules": [
    {
      "id": "REPORT_PAGES_WITH_BACKGROUND_IMAGE",
      "name": "Report pages with background images",
      "description": "Identifies all Power BI report pages that use background images",
      "itemType": "Report",
      "part": "Pages",
      "test": [
        {
          "map": [
            {
              "filter": [
                { "part": "" },
                {
                  "or": [
                    { "hasprop": [{ "var": "" }, "backgroundImage"] },
                    { "hasprop": [{ "var": "" }, "background"] },
                    {
                      "and": [
                        { "hasprop": [{ "var": "" }, "objects"] },
                        {
                          "some": [
                            { "var": "objects" },
                            { "==": [{ "var": "0.name" }, "pageBackground"] }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            { "var": "displayName" }
          ]
        },
        []
      ]
    }
  ]
}